# .env.example — Copia este archivo a .env y rellena los valores.
# El archivo .env nunca debe subirse al repositorio (ya está en .gitignore).

# ---------------------------------------------------------------------------
# Neo4j — conexión
# ---------------------------------------------------------------------------

# Usuario de Neo4j (normalmente "neo4j")
NEO4J_USER=neo4j

# Contraseña de Neo4j (OBLIGATORIO — sin valor por defecto)
NEO4J_PASSWORD=

# Ruta al ejecutable cypher-shell de tu instalación local de Neo4j Desktop
# Windows ejemplo:
#   CYPHER_SHELL_PATH=C:\Users\TuUsuario\.Neo4jDesktop2\Cache\dbmss\neo4j-enterprise-X.Y.Z\bin\cypher-shell.bat
# Linux/macOS ejemplo:
#   CYPHER_SHELL_PATH=/usr/bin/cypher-shell
CYPHER_SHELL_PATH=

# Directorio "import" de Neo4j donde se copian los CSV antes de LOAD CSV
# Windows ejemplo:
#   NEO4J_IMPORT_DIR=C:\Users\TuUsuario\.Neo4jDesktop2\Data\dbmss\dbms-XXXX\import
# Linux/macOS ejemplo:
#   NEO4J_IMPORT_DIR=/var/lib/neo4j/import
NEO4J_IMPORT_DIR=

# ---------------------------------------------------------------------------
# Neo4j — opcionales
# ---------------------------------------------------------------------------

# Etiqueta de nodo usada en el grafo (default: DataNode)
NEO4J_NODE_LABEL=DataNode

# Tipo de relación entre nodos (default: TIENE)
NEO4J_REL_TYPE=TIENE

# ---------------------------------------------------------------------------
# Pipeline — rutas (opcionales, tienen valores por defecto relativos al repo)
# ---------------------------------------------------------------------------

# Directorio donde json_to_graph.py escribe los CSV
# Por defecto: grafos/datos_grafos/ (relativo al repo)
# CSV_OUTPUT_DIR=

# ---------------------------------------------------------------------------
# EusKorpus — scraper EHAA/BOPV
# ---------------------------------------------------------------------------

# Directorio de salida de los JSON scrapeados (usado por ehaa_scraper.py)
# Por defecto: data/limpios_json/ehaa
# EHAA_OUTPUT_DIR=data/limpios_json/ehaa

# Pausa entre peticiones al portal BOPV en segundos (respetar al servidor)
# EHAA_RATE_LIMIT=1.5
